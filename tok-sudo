#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# ANSI colour tokens

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1;37m'
NC='\033[0m'

# ─────────────────────────────────────────────────────────────────────────────
# Output helpers

error() {
    echo -e "${RED}Error:${NC} $1" >&2
    exit 1
}

# ─────────────────────────────────────────────────────────────────────────────

VERSION="@VERSION@"

usage() {
    echo -e "${BOLD}tok-sudo${NC} — token-gated sudo wrapper"
    echo -e ""
    echo -e "${BOLD}Usage:${NC}"
    echo -e "  TOK_SUDO_TOKEN=<token> tok-sudo <command...>"
    echo -e ""
    echo -e "${BOLD}Options:${NC}"
    echo -e "  -h, --help       Show this help message"
    echo -e "  -v, --version    Show version"
    exit "${1:-0}"
}

[[ "${1:-}" != "--help" && "${1:-}" != "-h" ]]    || usage 0
[[ "${1:-}" != "--version" && "${1:-}" != "-v" ]] || { echo "tok-sudo $VERSION"; exit 0; }

[[ -n "${TOK_SUDO_TOKEN:-}" ]] || usage 1
[[ $# -ge 1 ]]                || usage 1

HASH=$(echo -n "$TOK_SUDO_TOKEN" | { sha256sum 2>/dev/null || shasum -a 256; } | cut -d' ' -f1)
if [[ -t 0 ]]; then
    echo "$HASH" | sudo /usr/local/bin/tok-sudo-exec "$@"
else
    set +o pipefail
    { echo "$HASH"; cat; } | sudo /usr/local/bin/tok-sudo-exec "$@"
fi
