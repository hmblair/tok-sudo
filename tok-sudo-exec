#!/usr/bin/env bash
# tok-sudo-exec — internal script, runs as root via sudoers NOPASSWD.
# Validates token hash against /etc/tok-sudo-token-hash, then executes the command.
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

HASH_FILE="/etc/tok-sudo-token-hash"

[[ $# -ge 1 ]] || { echo "tok-sudo-exec: missing arguments" >&2; exit 1; }

read -r PROVIDED_HASH

[[ -n "$PROVIDED_HASH" ]] || { echo "tok-sudo: empty token" >&2; exit 1; }

EXPECTED_HASH=$(cat "$HASH_FILE" 2>/dev/null) || {
    echo "tok-sudo: token not configured. Run: sudo tok-sudo-rotate" >&2
    exit 1
}

[[ -n "$EXPECTED_HASH" ]] || {
    echo "tok-sudo: token not configured. Run: sudo tok-sudo-rotate" >&2
    exit 1
}

if [[ "$PROVIDED_HASH" == "$EXPECTED_HASH" ]]; then
    exec "$@"
else
    echo "tok-sudo: invalid token" >&2
    exit 1
fi
