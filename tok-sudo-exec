#!/usr/bin/env bash
# tok-sudo-exec — internal script, runs as root via sudoers NOPASSWD.
# Validates token hash against /etc/tok-sudo-token-hash, then executes the command.
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# ─────────────────────────────────────────────────────────────────────────────
# ANSI colour tokens

RED='\033[0;31m'
NC='\033[0m'

# ─────────────────────────────────────────────────────────────────────────────
# Output helpers

error() {
    echo -e "${RED}Error:${NC} $1" >&2
    exit 1
}

# ─────────────────────────────────────────────────────────────────────────────

HASH_FILE="/etc/tok-sudo-token-hash"

sha256() { echo -n "$1" | { sha256sum 2>/dev/null || shasum -a 256; } | cut -d' ' -f1; }

file_owner_uid() {
    stat -c %u "$1" 2>/dev/null || stat -f %u "$1"
}

file_mode() {
    stat -c %a "$1" 2>/dev/null || stat -f %Lp "$1"
}

# ─────────────────────────────────────────────────────────────────────────────

[[ $# -ge 1 ]] || error "missing arguments"

if [[ -t 0 ]]; then
    error "tok-sudo-exec is an internal command. Use tok-sudo instead."
fi

read -r PROVIDED_HASH

[[ -n "$PROVIDED_HASH" ]] || error "empty token"

[[ "$PROVIDED_HASH" =~ ^[a-f0-9]{64}$ ]] || error "invalid token"

[[ -f "$HASH_FILE" ]] || error "token not configured. Run: sudo tok-sudo-rotate"

[[ ! -L "$HASH_FILE" ]] || error "$HASH_FILE is a symlink"

[[ "$(file_owner_uid "$HASH_FILE")" == "0" ]] || error "$HASH_FILE is not owned by root"

[[ "$(file_mode "$HASH_FILE")" == *00 ]] || error "$HASH_FILE is accessible to non-root users (mode $(file_mode "$HASH_FILE"))"

EXPECTED_HASH=$(cat "$HASH_FILE" 2>/dev/null) || error "token not configured. Run: sudo tok-sudo-rotate"

[[ -n "$EXPECTED_HASH" ]] || error "token not configured. Run: sudo tok-sudo-rotate"

[[ "$EXPECTED_HASH" =~ ^[a-f0-9]{64}$ ]] || error "token hash is malformed"

# Timing-safe comparison: re-hash both values with a random nonce so that
# the final string comparison leaks no information about the actual hashes.
NONCE=$(head -c 16 /dev/urandom | od -A n -t x1 | tr -d ' \n')
if [[ "$(sha256 "${NONCE}${PROVIDED_HASH}")" == "$(sha256 "${NONCE}${EXPECTED_HASH}")" ]]; then
    # Block self-rotation: prevent agents from rotating their own token
    [[ "$(basename "$1")" != "tok-sudo-rotate" ]] || error "tok-sudo-rotate cannot be run through tok-sudo"
    exec "$@"
else
    error "invalid token"
fi
