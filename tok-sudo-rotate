#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# ANSI colour tokens

GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

# ─────────────────────────────────────────────────────────────────────────────
# Output helpers

error() {
    echo -e "${RED}Error:${NC} $1" >&2
    exit 1
}

success() {
    echo -e "${GREEN}$1${NC}"
}

# ─────────────────────────────────────────────────────────────────────────────

VERSION="@VERSION@"

usage() {
    echo -e "${GREEN}tok-sudo-rotate${NC} — generate a new tok-sudo token"
    echo -e ""
    echo -e "Usage:"
    echo -e "  sudo tok-sudo-rotate"
    echo -e ""
    echo -e "Options:"
    echo -e "  -h, --help       Show this help message"
    echo -e "  -v, --version    Show version"
    exit "${1:-0}"
}

[[ "${1:-}" != "--help" && "${1:-}" != "-h" ]]    || usage 0
[[ "${1:-}" != "--version" && "${1:-}" != "-v" ]] || { echo "tok-sudo-rotate $VERSION"; exit 0; }

HASH_FILE="/etc/tok-sudo-token-hash"

[[ "$(id -u)" -eq 0 ]] || error "tok-sudo-rotate must be run as root (use sudo)"

TOKEN=$(head -c 128 /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c 32)

echo -n "$TOKEN" | { sha256sum 2>/dev/null || shasum -a 256; } | cut -d' ' -f1 > "$HASH_FILE"
chmod 600 "$HASH_FILE"

success "New tok-sudo token: $TOKEN"
